{% extends "bootstrap/form.j2" %}

{% block head %}
{{ super() }}
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
{% endblock %}

{% block style %}
{{ super() }}
{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="d-flex align-items-center justify-content-between mb-5 mt-2 px-0" style="width:100%; font-family: 'Open Sans';">
        <div style="flex: 1; text-align:left;">
            <img src="{{ url_for('static', filename='chea_kg_ts.png') }}" style="width:175px"
                class="img-fluid">
        </div>
        <div style="flex: 4; text-align: center; padding: 0 20px;">
            <h1 style="font-weight: bolder; color: rgb(0, 0, 79);"> ChEA-KG-TS </h1>
            <p class="my-0">
                ChIP-X Enrichment Analysis (ChEA) Knowledge Graph (KG) Time Series (TS) is a workflow for analysis time series gene expression datasets. 
                Upload a data matrix or a gene set library created from a time-series study to receive a comprehensive report that provides insights about the transcription factors responsible for the observed state transitions over time.
            </p>
        </div>
        <div style="flex: 1; text-align: center;">
            <div> Executed<br>Reports: </div> 
            <p style="font-weight: 900; font-size: 1.5rem" id="numruns"></p>
        </div>
    </div>

    <div id="help-content" class="container col-10" style="display: none; padding: 20px;">
        <div class="text-center mb-3">
            <button id="back-to-form-btn" class="btn btn-primary" type="button" onclick="showForm()">Back to Form</button>
        </div>
        <div id="markdown-container" style="background: white; padding: 30px; border-radius: 8px;"></div>
    </div>

    <div id="form-content" class="text-center justify-content-center mx-auto">
        <div class="row">
            <div class="col-12">
                <div id="selector" class="row mx-auto justify-content-center gap-5 mb-0">
                        <div id="RNA-seq-button" class="col-3 justify-content-center question">
                            Time Series Data Matrix
                        </div>
                        <div id="GMT-button" class="col-3 justify-content-center question">
                            Time Series Gene Set Library
                        </div>
                    </div>

                <div class="container col-10" style="font-size: 14px !important;"></div>
                <form method="POST" enctype="multipart/form-data" action="" onsubmit="return onSubmit(event)">
                    <div hidden>
                        {{ _fields[1].render() }}
                    </div>
                    
                    <div id="RNA-seq" style="display: none;">
                        <div class="row mx-auto justify-content-center gap-5 mb-3">
                            <div class="btn rounded col-3 justify-content-center" style="border: solid 2px rgb(103, 103, 103); font-weight: 500; font-size: 20px; background-color: rgb(204, 230, 237); margin-top: 20px; padding: 20px" 
                                    onclick="loadTRAILExampleRNA()">Load example RNA-seq data<br> (TRAIL Treatment of TNBC)</div>
                        </div>
                        
                        
                        <div class="row justify-content-evenly">
                            <div class="col-6">
                                {{ _fields[4].render() }}
                            </div>
                            <div class="col-6">
                                {{ _fields[5].render() }}
                            </div>
                        </div>
                        <div id="rna-options" class="row justify-content-evenly" style="display: none;">
                        <div class="col-4">
                                {{ _fields[8].render() }}
                            </div>
                        <div class="col-4">
                                {{ _fields[9].render() }}
                        </div>
                    </div>
                    </div>

                    <div id="GMT" style="display: none;">
                        <div class="row mx-auto justify-content-center gap-5 mb-3">
                            <div class="btn rounded col-3 justify-content-center" style="border: solid 2px rgb(103, 103, 103); font-weight: 500; font-size: 20px; 
                            background-color: rgb(204, 230, 237); margin-top: 20px; padding: 20px" onclick="loadTRAILExampleGMT()">
                                Load example GMT files <br>(TRAIL Treatment of TNBC)
                            </div>
                        </div>
                        
                        <div class="row justify-content-evenly">
                            <div class="col-6">
                                {{ _fields[6].render() }}
                            </div>
                            <div class="col-6">
                                {{ _fields[7].render() }}
                            </div>
                        </div>
                        <div id="gmt-options" class="row justify-content-evenly" style="display: none;">
                        <div class="col-4">
                                {{ _fields[9].render() }}
                        </div>
                    </div>
                        
                    </div>

                    <div id="shared-area" class="row justify-content-evenly" style="display: none;">
                        <div class="col-9">
                                {{ _fields[2].render() }}
                            </div>
                        <div class="col-9">
                                {{ _fields[3].render() }}
                        </div>
                    </div>
                    


                    

                    <div id="submit-area" class="row" style="display: none;">
                        <div class="col-sm-12">
                            <input type="submit" value="Submit" />
                            <div id="submit-feedback" class="p-2 px-5 rounded mx-auto"
                                style="position: absolute; background-color: rgba(255, 0, 0, 0.552);">
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}


{% block script %}
{{ super() }}

<script>

    async function loadHelp() {
        try {
            const response = await fetch("{{ url_for('static', filename='help.md') }}");
            const markdown = await response.text();
            document.getElementById('markdown-container').innerHTML = marked.parse(markdown);
        } catch (error) {
            console.error('Error loading help page:', error);
            document.getElementById('markdown-container').innerHTML = '<p>Error loading help page.</p>';
        }
    }

    document.getElementById('toggle-help-btn').addEventListener('click', () => {
        document.getElementById('form-content').style.display = 'none'
        document.getElementById('help-content').style.display = 'block'
        loadHelp()
    });

    document.getElementById('back-to-form-btn').addEventListener('click', () => {
        document.getElementById('help-content').style.display = 'none'
        document.getElementById('form-content').style.display = 'block'
    })

    document.getElementById('RNA-seq-button').addEventListener('click', () => {
        $('#ga').fadeOut(50)
        $('#GMT').fadeOut(50)
        $('#RNA-seq').fadeIn(50)
        $('#shared-area').fadeIn()
        $('#submit-area').fadeIn(1000)
        
        $('#gmt-options').hide()
        $('#gmt-options input, #gmt-options select').prop('disabled', true)  // disable to prevent submission
        
        $('#rna-options').show()
        $('#rna-options input, #rna-options select').prop('disabled', false)
        
        document.forms[0].elements['input_data_type'].value = 'raw RNA-seq data';
        $('#RNA-seq-button').addClass('selected')
        $('#GMT-button').removeClass('selected')
    })

    document.getElementById('GMT-button').addEventListener('click', () => {
        $('#ga').fadeOut(50)
        $('#RNA-seq').fadeOut(50)
        $('#GMT').fadeIn(50)
        $('#rna-options').hide()
        $('#rna-options input, #rna-options select').prop('disabled', true)  // disable to prevent submission
        
        $('#gmt-options').show()
        $('#gmt-options input, #gmt-options select').prop('disabled', false)
        $('#shared-area').fadeIn()
        $('#submit-area').fadeIn(1000)
        document.forms[0].elements['input_data_type'].value = 'GMT';
        $('#RNA-seq-button').removeClass('selected')
        $('#GMT-button').addClass('selected')
    })

    function loadTRAILExampleRNA() {
        const textbtn = document.getElementsByClassName('text-btn ' + 'GSE271120');
        for (let i = 0; i < textbtn.length; i++) {
            textbtn[i].click();
        }
        document.forms[0].elements['dge_method'].value = 'DESeq2'
        
    }

    function loadTRAILExampleGMT() {
        const textbtn = document.getElementsByClassName('text-btn ' + 'deseq2');
        for (let i = 0; i < textbtn.length; i++) {
            textbtn[i].click();
        }

        
    }

    async function validate(formData) {
    
        const countMatrix = formData.get('count_matrix');
        console.log('count_matrix:', countMatrix);
        console.log('count_matrix type:', typeof countMatrix);
        console.log('Is File?', countMatrix instanceof File);

    
        console.warn(Object.fromEntries(formData.entries()))

        if (formData.get('input_data_type') == 'raw RNA-seq data') {
    
            if (!formData.get('count_matrix')) throw new Error('Please provide RNA-seq gene count matrix')
            if (!formData.get('metadata')) throw new Error('Please provide sample metadata')
        }
        if (formData.get('input_data_type') == 'GMT') {

            if (!formData.get('gmt_adjacent')) throw new Error('Please provide GMT comparing adjacent timepoints')
            if (!formData.get('gmt_t0')) throw new Error('Please provide sample GMT comparing to time zero')
        }
        }


        async function doSubmit(formData) {
            await validate(formData)
            const json = Object.fromEntries(formData.entries())
            const res = await fetch(window.location.href, {
                method: 'POST',
                headers: {
                    'Accept': 'application/json',
                },
                body: formData, 
            })
            if (res.status === 406) {
                let { error } = await res.json()
                throw new Error(error.message)
            } else {
                const { _id } = await res.json()
                window.location.href = `${_id}/`
            }
        }

        function onSubmit(e) {
        e.preventDefault()
        const formData = new FormData(e.target)
        doSubmit(formData).catch(function (e) {
            console.error(e)
            document.getElementById('submit-feedback').innerText = e.toString()
            document.getElementById('submit-feedback').style.visibility = 'visible';
            document.getElementById('submit-feedback').style.opacity = 1;
            //setTimeout(() => {
            //    document.getElementById('submit-feedback').style.opacity = 0;
            //}, 5000)
        })
    }

    function getNumRuns() {
        fetch('/blueprint/numruns').then(response => response.json()).then(data => {
            document.getElementById('numruns').innerText = data.num_runs;
        })
    }
    getNumRuns()
</script>
{% endblock %}