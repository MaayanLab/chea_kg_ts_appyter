{% extends "base.j2" %}

{% block script_head %}
{{ super() }}
{% if 'ipywidgets' in _config.EXTRAS %}
<script>
require.config({
  paths: {
    '@jupyter-widgets/html-manager': 'https://unpkg.com/@jupyter-widgets/html-manager@*/dist/embed-amd',
  }
})
define('@appyter/ipywidgets-manager', ['@jupyter-widgets/html-manager'], function (htmlmanager) {
  const manager = new htmlmanager.HTMLManager({ loader: htmlmanager.requireLoader })
  return manager
})
</script>
{% endif %}
{% endblock %}

{% block body %}
{{ super() }}
<h3 style="text-align: center">The execution of the full report may take several minutes to complete.<br> You can save this report’s URL and return to see the results later.</h3>
<div class="row">
  <div class="col-sm-12">
    {% include "fragments/jupyter.j2" %}

    <div id="_content" class="svelte container loading">
      {% include "fragments/loader.j2" %}
      <script type="application/json">{{ dict(nbdownload=_nb, js_url=url_for('static', filename='js/landing.js'))|jsonify }}</script>
    </div>
  </div>
</div>
<div id="help-overlay" class="hidden" style="position: fixed; top:0; left:0; width:100%; height:100%; 
  background-color: rgba(0,0,0,0.5); z-index: 1000; overflow-y: auto;">

    <div style="background: white; margin: 5% auto; padding: 20px; border-radius: 8px; width: 80%; position: relative;">
        <button onclick="toggleHelp()" 
                style="position: absolute; top: 10px; right: 10px; font-size: 16px;">✖ Close</button>
        
        <div id="markdown-container"></div>
    </div>
</div>
{% endblock %}
