<div class="row px-4 px-lg-3 pb-4">
  <div class="col-lg-3 bold text-lg-right my-auto mt-2 mr-0">
    {{ this.args.label }}:
    {%- if this.args.description %}
      <sup data-toggle="tooltip" title="{{ this.args.description }}"><i class="far fa-question-circle"></i></sup>
    {% endif -%}
  </div>
  <div class="col-lg-6 pt-10 pt-lg-0">
    <input
        name="{{ this.args.name }}"
        placeholder="{{ this.args.hint }}"
        class="form-control nodecoration tiny"
    >
  </div>
</div>